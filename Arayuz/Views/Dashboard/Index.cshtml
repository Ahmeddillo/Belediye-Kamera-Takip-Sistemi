</style>

@section Scripts {
    <script>
        const LOCAL_API_URL = '/Dashboard/TumKameralarDurum';
        let saatlikChart  = null;
        let haftalikChart = null;

        Chart.defaults.font.family = "'DM Sans', sans-serif";
        Chart.defaults.color = '#64748B';

        // ── Hava durumu sabit verileri ──
        const HAVA_IKON = {
            "Gunesli":          "☀",
            "Parcali Bulutlu":  "⛅",
            "Bulutlu / Kapali": "☁",
            "Yagmurlu / Islak": "🌧",
            "Karli / Sisli":    "❄",
            "Gece / Karanlik":  "🌙",
            "Kirli Lens":       "⚠"
        };
        const HAVA_RENK = {
            "Gunesli":          "#f59e0b",
            "Parcali Bulutlu":  "#94a3b8",
            "Bulutlu / Kapali": "#64748b",
            "Yagmurlu / Islak": "#60a5fa",
            "Karli / Sisli":    "#cbd5e1",
            "Gece / Karanlik":  "#94a3b8",
            "Kirli Lens":       "#f87171"
        };

        // ── Canlı Güncelleme ──
        async function canliVerileriGuncelle() {
            try {
                const res    = await fetch(LOCAL_API_URL);
                if (!res.ok) throw new Error("Veri çekilemedi");
                const veriler = await res.json();

                let anlikToplam = 0;
                veriler.forEach(k => {
                    const el = document.getElementById(`kamera-kisi-${k.id}`);
                    if (el) {
                        const eskiDeger = parseInt(el.textContent) || 0;
                        el.textContent  = k.kisiSayisi;
                        if (eskiDeger !== k.kisiSayisi) {
                            el.style.color      = '#2563EB';
                            el.style.fontWeight = 'bold';
                            setTimeout(() => { el.style.color = ''; el.style.fontWeight = ''; }, 1000);
                        }
                    }
                    anlikToplam += k.kisiSayisi;
                });

                document.getElementById('kpi-anlik').textContent = anlikToplam;
                document.getElementById('kpi-zaman').textContent =
                    new Date().toLocaleTimeString('tr-TR');

                const gEl = document.getElementById('kamera-guncelleme-zaman');
                if (gEl) gEl.textContent =
                    new Date().toLocaleTimeString('tr-TR', { hour:'2-digit', minute:'2-digit' });
            } catch (e) {
                console.error('Canlı veri hatası:', e);
            }
        }

        // ── Saatlik Grafik ──
        async function saatlikGrafikYukle(kameraId) {
            try {
                const res = await fetch(`/Dashboard/SaatlikGrafik?kameraId=${kameraId}`);
                const d   = await res.json();

                if (d.toplamKisi !== undefined)
                    document.getElementById('kpi-bugun').textContent =
                        d.toplamKisi.toLocaleString('tr-TR');

                if (!d.labels || d.labels.length === 0) return;

                const ctx = document.getElementById('saatlikGrafik').getContext('2d');
                if (saatlikChart) saatlikChart.destroy();

                saatlikChart = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: d.labels,
                        datasets: [
                            {
                                label: 'Ortalama Kişi',
                                data: d.data,
                                backgroundColor: 'rgba(37,99,235,0.15)',
                                borderColor: '#2563EB',
                                borderWidth: 2,
                                borderRadius: 5,
                                order: 2
                            },
                            {
                                label: 'Pik Kişi',
                                data: d.pikData,
                                type: 'line',
                                borderColor: '#C8901A',
                                backgroundColor: 'rgba(200,144,26,0.1)',
                                borderWidth: 2.5,
                                pointBackgroundColor: '#C8901A',
                                pointRadius: 4,
                                tension: 0.4,
                                fill: false,
                                order: 1
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { position: 'top' } },
                        scales: {
                            x: { grid: { display: false } },
                            y: { beginAtZero: true, grid: { color: '#F1F5F9' } }
                        }
                    }
                });
            } catch (e) { console.warn('Saatlik grafik yüklenemedi:', e); }
        }

        // ── Haftalık Trend ──
        async function haftalikGrafikYukle(kameraId) {
            try {
                const res = await fetch(`/Dashboard/HaftalikGrafik?kameraId=${kameraId}`);
                const d   = await res.json();
                if (!d.labels || d.labels.length === 0) return;

                const ctx      = document.getElementById('haftalikGrafik').getContext('2d');
                const gradient = ctx.createLinearGradient(0, 0, 0, 300);
                gradient.addColorStop(0, 'rgba(37,99,235,0.25)');
                gradient.addColorStop(1, 'rgba(37,99,235,0)');

                if (haftalikChart) haftalikChart.destroy();

                haftalikChart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: d.labels,
                        datasets: [{
                            label: 'Günlük Toplam Kişi',
                            data: d.data,
                            borderColor: '#1A4A8A',
                            backgroundColor: gradient,
                            borderWidth: 2.5,
                            pointBackgroundColor: '#2563EB',
                            pointRadius: 5,
                            tension: 0.35,
                            fill: true
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: {
                            x: { grid: { display: false } },
                            y: { beginAtZero: true, grid: { color: '#F1F5F9' } }
                        }
                    }
                });
            } catch (e) { console.warn('Haftalık grafik yüklenemedi:', e); }
        }

        // ── ++ Hava Durumu Önizleme (tüm kameralar) ──
        async function havaOnizlemeGuncelle() {
            const konteyner = document.getElementById('hava-onizleme-listesi');
            try {
                // Kamera listesini zaten biliyoruz, her biri için ayrı çek
                const kameraIdleri = [@Html.Raw(string.Join(",", Model.Kameralar.Select(k => k.Id)))];

                if (kameraIdleri.length === 0) {
                    konteyner.innerHTML =
                        '<span style="color:rgba(255,255,255,.4); font-size:13px;">Kamera bulunamadı.</span>';
                    return;
                }

                const sonuclar = await Promise.all(
                    kameraIdleri.map(id =>
                        fetch(`/Dashboard/HavaDurumuCanli?kameraId=${id}`)
                            .then(r => r.json())
                            .then(d => ({ id, ...d }))
                            .catch(() => ({ id, durum: 'Veri yok', guvenOrani: 0, tespitZamani: '' }))
                    )
                );

                // Kamera adlarını SSR'dan al
                const kameraAdlari = {
        @foreach (var k in Model.Kameralar)
        {
            @Html.Raw($"{k.Id}: \"{k.Ad} — {k.Konum}\",")
        }
                };

                konteyner.innerHTML = sonuclar.map(s => {
                    const ikon  = HAVA_IKON[s.durum] ?? '?';
                    const renk  = HAVA_RENK[s.durum] ?? '#94a3b8';
                    const saat  = s.tespitZamani?.length >= 19
                        ? s.tespitZamani.substring(11, 19) : '--:--';
                    const ad    = kameraAdlari[s.id] ?? `Kamera ${s.id}`;
                    const guven = typeof s.guvenOrani === 'number'
                        ? s.guvenOrani.toFixed(1) : s.guvenOrani;

                    return `
                        <div style="display:flex; align-items:center; gap:10px;
                                    background:rgba(255,255,255,.07); border:1px solid rgba(255,255,255,.12);
                                    border-radius:10px; padding:12px 16px; min-width:220px;">
                            <span style="font-size:30px; line-height:1;">${ikon}</span>
                            <div>
                                <div style="font-size:15px; font-weight:700; color:${renk};">
                                    ${s.durum}
                                </div>
                                <div style="font-size:11px; color:rgba(255,255,255,.45); margin-top:2px;">
                                    ${ad}
                                </div>
                                <div style="font-size:11px; color:rgba(255,255,255,.35);">
                                    %${guven} · ${saat}
                                </div>
                            </div>
                        </div>
                    `;
                }).join('');

            } catch (e) {
                konteyner.innerHTML =
                    '<span style="color:rgba(255,255,255,.35); font-size:13px;">API bağlantısı yok</span>';
            }
        }

        // ── Sayfa Başlangıç ──
        document.addEventListener('DOMContentLoaded', () => {
            const varsayilanId = @ilkKameraId;

            canliVerileriGuncelle();
            saatlikGrafikYukle(varsayilanId);
            haftalikGrafikYukle(varsayilanId);
            havaOnizlemeGuncelle();

            setInterval(canliVerileriGuncelle, 3000);
            setInterval(havaOnizlemeGuncelle, 30000);   // ++ 30sn'de bir güncelle

            setInterval(() => {
                const s1 = document.getElementById('grafik-kamera-sec').value;
                saatlikGrafikYukle(s1);
                const s2 = document.getElementById('trend-kamera-sec').value;
                haftalikGrafikYukle(s2);
            }, 60000);
        });

        // ── Plaka Tanıma ──
        function plakaDrop(e) {
            e.preventDefault();
            document.getElementById('plaka-drop-alan').style.borderColor = 'var(--border-color)';
            const f = e.dataTransfer.files[0];
            if (f) plakaYukle(f);
        }

        function plakaTemizle() {
            document.getElementById('plaka-sonuclar').innerHTML = '';
            document.getElementById('plaka-onizleme').style.display = 'none';
            document.getElementById('plaka-dosya').value = '';
        }

        async function plakaYukle(dosya) {
            if (!dosya) return;

            // Önizleme göster
            const reader = new FileReader();
            reader.onload = e => {
                document.getElementById('plaka-onizleme-img').src = e.target.result;
                document.getElementById('plaka-onizleme').style.display = 'block';
            };
            reader.readAsDataURL(dosya);

            document.getElementById('plaka-yukleniyor').style.display = 'block';
            document.getElementById('plaka-sonuclar').innerHTML = '';

            const form = new FormData();
            form.append('dosya', dosya);

            try {
                const res  = await fetch('/Dashboard/PlakaIsle', { method: 'POST', body: form });
                const data = await res.json();

                document.getElementById('plaka-yukleniyor').style.display = 'none';

                if (data.hata) {
                    document.getElementById('plaka-sonuclar').innerHTML =
                        `<div class="alert alert-danger" style="color:#1F2937 !important;">${data.hata}</div>`;
                    return;
                }

                if (!Array.isArray(data) || data.length === 0) {
                    document.getElementById('plaka-sonuclar').innerHTML =
                        `<div class="alert alert-warning" style="color:#1F2937 !important;">Plaka tespit edilemedi.</div>`;
                    return;
                }


        document.getElementById('plaka-sonuclar').innerHTML = data.map(s => `
            <div style="background:var(--sidebar-bg); border:1px solid var(--border-color);
                        border-radius:10px; padding:20px; margin-bottom:10px;
                        display:flex; justify-content:space-between; align-items:center;
                        position:relative; z-index:1000;">
                <div style="flex:1;">

                    <div style="font-size:30px; color:var(--text-secondary);
                                display:block; visibility:visible; opacity:1;">
                        Ham: ${s.hamMetin} &nbsp;|&nbsp; Düzeltilmiş: ${s.duzeltilmisMetin}
                    </div>
                </div>
                <div style="text-align:right; margin-left:20px;">
                    <span style="display:inline-block; padding:6px 14px; border-radius:20px;
                                 font-size:30px; font-weight:700;
                                 background:${s.gecerli ? 'rgba(34,197,94,.15)' : 'rgba(248,113,113,.15)'};
                                 color:${s.gecerli ? '#22c55e' : '#f87171'};
                                 position:relative; z-index:1001;">
                        ${s.gecerli ? '✅ Geçerli' : '⚠ Geçersiz'}
                    </span>
                    <div style="font-size:30px; color:var(--text-secondary); margin-top:8px;
                                display:block; visibility:visible; opacity:1;">
                        Tespit %${(s.tespitGuven * 100).toFixed(0)}
                        · OCR %${(s.ocrGuven * 100).toFixed(0)}
                    </div>
                </div>
            </div>
        `).join('');

            } catch {
                document.getElementById('plaka-yukleniyor').style.display = 'none';
                document.getElementById('plaka-sonuclar').innerHTML =
                    `<div class="alert alert-danger" style="color:#1F2937 !important;">Servise bağlanılamadı.</div>`;
            }
        }

        // ── Araç Sayım ──
        let _aracEventSource = null;

        function aracSayTemizle() {
            aracDurdur();
            document.getElementById('arac-url-input').value      = '';
            document.getElementById('arac-max-kare').value       = '0';
            document.getElementById('arac-video-img').style.display     = 'none';
            document.getElementById('arac-video-img').src               = '';
            document.getElementById('arac-video-placeholder').style.display = 'flex';
            document.getElementById('stat-anlik').textContent    = '0';
            document.getElementById('stat-en-yuksek').textContent = '0';
            document.getElementById('stat-siniflar').innerHTML   =
                '<div style="font-size:12px; color:var(--text-secondary);">—</div>';
            document.getElementById('arac-durum-metin').textContent  = '—';
            document.getElementById('arac-kare-sayaci').textContent  = 'Kare: 0';
        }

        function aracDurdur() {
            if (_aracEventSource) {
                _aracEventSource.close();
                _aracEventSource = null;
            }

            // MJPEG akışını kes
            const img = document.getElementById('arac-video-img');
            img.src = '';
            img.style.display = 'none';
            document.getElementById('arac-video-placeholder').style.display = 'flex';

            // Worker'ı kapat
            const url = document.getElementById('arac-url-input').value.trim();
            if (url) {
                fetch(`http://localhost:8000/api/arac-stream-durdur?kaynak=${encodeURIComponent(url)}`,
                      { method: 'DELETE' }).catch(() => {});
            }

            document.getElementById('arac-say-btn').disabled = false;
            document.getElementById('arac-say-btn').style.opacity = '1';
            document.getElementById('arac-dur-btn').disabled = true;
            document.getElementById('arac-dur-btn').style.opacity = '.5';
            document.getElementById('arac-yukleniyor').style.display = 'none';
            document.getElementById('arac-durum-metin').textContent = 'Durduruldu';
        }

        function aracSayBaslat() {
            const url     = document.getElementById('arac-url-input').value.trim();
            const maxKare = document.getElementById('arac-max-kare').value || 0;

            if (!url) {
                document.getElementById('arac-durum-metin').textContent = '⚠ URL boş olamaz';
                return;
            }

            // Önceki akışı temizle
            aracDurdur();

            document.getElementById('arac-yukleniyor').style.display = 'block';
            document.getElementById('arac-say-btn').disabled   = true;
            document.getElementById('arac-say-btn').style.opacity  = '.5';
            document.getElementById('arac-dur-btn').disabled   = false;
            document.getElementById('arac-dur-btn').style.opacity  = '1';
            document.getElementById('arac-durum-metin').textContent = 'Bağlanıyor...';

            const base = `http://localhost:8000`;
            const enc  = encodeURIComponent(url);

            // 1) MJPEG akışını <img>'e bağla
            const img = document.getElementById('arac-video-img');
            img.onload = () => {
                document.getElementById('arac-yukleniyor').style.display = 'none';
                document.getElementById('arac-video-placeholder').style.display = 'none';
                img.style.display = 'block';
                document.getElementById('arac-durum-metin').textContent = '🔴 Canlı';
            };
            img.onerror = () => {
                document.getElementById('arac-yukleniyor').style.display = 'none';
                document.getElementById('arac-durum-metin').textContent = '⚠ Video akışı bağlanamadı';
            };
            img.src = `${base}/api/arac-video-stream?kaynak=${enc}&max_kare=${maxKare}`;

            // 2) SSE istatistik akışını aç
            _aracEventSource = new EventSource(
                `${base}/api/arac-istatistik-stream?kaynak=${enc}&max_kare=${maxKare}`
            );

            _aracEventSource.onmessage = function(e) {
                const d = JSON.parse(e.data);

                if (d.hata) {
                    document.getElementById('arac-durum-metin').textContent = `⚠ ${d.hata}`;
                    aracDurdur();
                    return;
                }

                if (d.bitti) {
                    document.getElementById('arac-durum-metin').textContent =
                        `✓ Tamamlandı — ${d.islenen_kare} kare işlendi`;
                    aracDurdur();
                    return;
                }

                // Anlık sayım
                document.getElementById('stat-anlik').textContent     = d.toplam_su_an ?? 0;
                document.getElementById('stat-en-yuksek').textContent = d.toplam_en_yuksek ?? 0;
                document.getElementById('arac-kare-sayaci').textContent = `Kare: ${d.kare}`;

                // Sınıf listesi — her iki sütun: anlık | max
                const satirlar = Object.entries(d.en_yuksek || {})
                    .sort((a, b) => b[1] - a[1])
                    .map(([cls, max]) => {
                        const anlik = (d.kare_sayimlari || {})[cls] || 0;
                        return `
                            <div style="display:flex; justify-content:space-between;
                                        align-items:center; padding:4px 0;
                                        border-bottom:1px solid var(--border-color);">
                                <span style="font-size:12px; display:flex; align-items:center; gap:5px;">
                                    <i class="bi bi-truck" style="color:#16a34a;"></i>${cls}
                                </span>
                                <span style="font-size:12px; font-weight:700;">
                                    <span style="color:#16a34a;">${anlik}</span>
                                    <span style="color:var(--text-secondary); font-weight:400;"> / </span>
                                    <span style="color:#3b82f6;">${max}</span>
                                </span>
                            </div>`;
                    }).join('');

                document.getElementById('stat-siniflar').innerHTML = satirlar ||
                    '<div style="font-size:12px; color:var(--text-secondary);">Tespit bekleniyor...</div>';
            };

            _aracEventSource.onerror = () => {
                // RTSP'de SSE bazen geçici kesiliyor, hemen bağlantıyı kopartmıyoruz
                document.getElementById('arac-durum-metin').textContent = '⚠ İstatistik bağlantısı kesildi';
            };
        }

        // ── Trafik Yoğunluk ──
                let _trafikEventSource = null;
        let _trafikGecmis      = [];

        function trafikTemizle() {
            trafikDurdur();
            document.getElementById('trafik-url-input').value            = '';
            document.getElementById('trafik-video-img').src              = '';
            document.getElementById('trafik-video-img').style.display    = 'none';
            document.getElementById('trafik-placeholder').style.display  = 'flex';
            document.getElementById('trafik-etiket').textContent         = '—';
            document.getElementById('trafik-oran').textContent           = 'Değişim: —';
            document.getElementById('trafik-ortalama').textContent       = '—';
            document.getElementById('trafik-maksimum').textContent       = '—';
            document.getElementById('trafik-durum-metin').textContent    = '—';
            document.getElementById('trafik-kare-sayaci').textContent    = 'Kare: 0';
            _trafikGecmis = [];
            trafikGrafikCiz([]);
        }

        function trafikDurdur() {
            if (_trafikEventSource) {
                _trafikEventSource.close();
                _trafikEventSource = null;
            }

            const img = document.getElementById('trafik-video-img');
            img.src = '';
            img.style.display = 'none';
            document.getElementById('trafik-placeholder').style.display = 'flex';

            const url = document.getElementById('trafik-url-input').value.trim();
            if (url) {
                fetch(`http://localhost:8000/api/trafik-stream-durdur?kaynak=${encodeURIComponent(url)}`,
                      { method: 'DELETE' }).catch(() => {});
            }

            document.getElementById('trafik-baslat-btn').disabled       = false;
            document.getElementById('trafik-baslat-btn').style.opacity  = '1';
            document.getElementById('trafik-dur-btn').disabled          = true;
            document.getElementById('trafik-dur-btn').style.opacity     = '.5';
            document.getElementById('trafik-yukleniyor').style.display  = 'none';
            document.getElementById('trafik-durum-metin').textContent   = 'Durduruldu';
        }

        function _trafikVideoGoster() {
            document.getElementById('trafik-yukleniyor').style.display  = 'none';
            document.getElementById('trafik-placeholder').style.display = 'none';
            document.getElementById('trafik-video-img').style.display   = 'block';
            document.getElementById('trafik-durum-metin').textContent   = '🔴 Canlı';
        }

        function trafikBaslat() {
            const url = document.getElementById('trafik-url-input').value.trim();
            if (!url) {
                document.getElementById('trafik-durum-metin').textContent = '⚠ URL boş olamaz';
                return;
            }

            trafikDurdur();
            _trafikGecmis = [];

            document.getElementById('trafik-yukleniyor').style.display  = 'block';
            document.getElementById('trafik-baslat-btn').disabled       = true;
            document.getElementById('trafik-baslat-btn').style.opacity  = '.5';
            document.getElementById('trafik-dur-btn').disabled          = false;
            document.getElementById('trafik-dur-btn').style.opacity     = '1';
            document.getElementById('trafik-durum-metin').textContent   = 'Bağlanıyor...';

            const enc  = encodeURIComponent(url);
            const base = 'http://localhost:8000';

            // MJPEG video — src'yi bağla, gösterimi SSE'ye bırak
            const img = document.getElementById('trafik-video-img');
            img.style.display = 'none';
            img.onerror = () => {
                document.getElementById('trafik-durum-metin').textContent = '⚠ Video bağlanamadı';
            };
            img.src = `${base}/api/trafik-video-stream?kaynak=${enc}`;

            // SSE istatistik
            _trafikEventSource = new EventSource(`${base}/api/trafik-istatistik-stream?kaynak=${enc}`);

            _trafikEventSource.onmessage = function(e) {
                const d = JSON.parse(e.data);

                if (d.hata) {
                    document.getElementById('trafik-durum-metin').textContent = `⚠ ${d.hata}`;
                    trafikDurdur();
                    return;
                }

                // Her durumda (öğrenme dahil) videoyu göster — stream başlamış demektir
                _trafikVideoGoster();

                // Arka plan öğreniliyor
                if (d.ogreniliyor) {
                    document.getElementById('trafik-durum-metin').textContent =
                        `Arka plan öğreniliyor... %${d.ilerleme}`;
                    return;
                }

                // Etiket rengi
                const renkler = { YOGUN: '#dc2626', NORMAL: '#f97316', SAKIN: '#16a34a' };
                const renk    = renkler[d.etiket] || '#2563eb';

                document.getElementById('trafik-etiket').textContent      = d.etiket || '—';
                document.getElementById('trafik-etiket').style.color      = renk;
                document.getElementById('trafik-oran').textContent        = `Değişim: %${d.oran}`;
                document.getElementById('trafik-ortalama').textContent    = `%${d.ortalama}`;
                document.getElementById('trafik-maksimum').textContent    = `%${d.maksimum}`;
                document.getElementById('trafik-kare-sayaci').textContent = `Kare: ${d.kare}`;
                document.getElementById('trafik-durum-metin').textContent = '🔴 Canlı';

                // Kart kenarlık rengi
                const kart = document.getElementById('trafik-yogunluk-kart');
                kart.style.borderColor = renk + '55';
                kart.style.background  = renk + '18';

                // Grafik
                if (d.gecmis && d.gecmis.length > 0) {
                    trafikGrafikCiz(d.gecmis);
                }
            };

            _trafikEventSource.onerror = () => {
                document.getElementById('trafik-durum-metin').textContent = '⚠ Bağlantı kesildi';
            };
        }

        function trafikGrafikCiz(veri) {
            const canvas = document.getElementById('trafik-grafik');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            const W   = canvas.offsetWidth || 180;
            const H   = canvas.height;
            canvas.width = W;

            ctx.clearRect(0, 0, W, H);

            if (veri.length < 2) return;

            const maks   = Math.max(...veri, 1);
            const adim_x = W / (veri.length - 1);

            // Arka plan grid
            ctx.strokeStyle = 'rgba(255,255,255,0.05)';
            ctx.lineWidth   = 1;
            [0.25, 0.5, 0.75].forEach(oran => {
                const y = H - (oran * H);
                ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();
            });

            // Çizgi
            ctx.lineWidth = 2;
            ctx.lineJoin  = 'round';
            ctx.beginPath();
            veri.forEach((v, i) => {
                const x = i * adim_x;
                const y = H - (v / maks) * H;
                i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
            });

            const son = veri[veri.length - 1];
            ctx.strokeStyle = son >= 18 ? '#dc2626' : son >= 9 ? '#f97316' : '#16a34a';
            ctx.stroke();

            // Dolgu
            ctx.lineTo((veri.length - 1) * adim_x, H);
            ctx.lineTo(0, H);
            ctx.closePath();
            ctx.fillStyle = son >= 18 ? 'rgba(220,38,38,.15)'
                          : son >= 9  ? 'rgba(249,115,22,.15)'
                          : 'rgba(22,163,74,.15)';
            ctx.fill();
        }
    </script>
}
