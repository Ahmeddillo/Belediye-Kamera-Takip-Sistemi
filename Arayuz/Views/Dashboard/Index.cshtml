<!-- index.cshtml -->
@model BelediyeDashboard.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var ilkKameraId = Model.Kameralar.FirstOrDefault()?.Id ?? 1;
}

@* API Bağlantı Uyarısı *@
@if (TempData["Hata"] != null)
{
    <div class="api-uyari">
        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
        <div>
            <strong>API Bağlantı Hatası:</strong> @TempData["Hata"]<br>
            <small>FastAPI servisini başlatmak için: <code>uvicorn api:app --reload --port 8000</code></small>
        </div>
    </div>
}

<!-- KPI SATIRLARI -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-sm-6">
        <div class="kpi-card mavi">
            <div class="kpi-icon"><i class="bi bi-people-fill"></i></div>
            <div class="kpi-label">Anlık Toplam Kişi</div>
            <div class="kpi-value" id="kpi-anlik">@Model.ToplamAnlikKisi</div>
            <div class="kpi-meta">Tüm kameralar birleşik</div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="kpi-card yesil">
            <div class="kpi-icon"><i class="bi bi-camera-video-fill"></i></div>
            <div class="kpi-label">Aktif Kamera</div>
            <div class="kpi-value">@Model.AktifKameraSayisi</div>
            <div class="kpi-meta">@Model.Kameralar.Count kameradan @Model.AktifKameraSayisi aktif</div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="kpi-card altin">
            <div class="kpi-icon"><i class="bi bi-graph-up-arrow"></i></div>
            <div class="kpi-label">Bugün Toplam Kişi</div>
            <div class="kpi-value" id="kpi-bugun">
                @(Model.SaatlikRaporlar.Values.FirstOrDefault()?.ToplamKisi ?? 0)
            </div>
            <div class="kpi-meta">@DateTime.Now.ToString("dd MMMM yyyy")</div>
        </div>
    </div>
    <div class="col-xl-3 col-sm-6">
        <div class="kpi-card turuncu">
            <div class="kpi-icon"><i class="bi bi-activity"></i></div>
            <div class="kpi-label">Son Güncelleme</div>
            <div class="kpi-value" style="font-size:24px;" id="kpi-zaman">@Model.SonGuncelleme</div>
            <div class="kpi-meta">Anlık ölçüm zamanı</div>
        </div>
    </div>
</div>

<!-- SAATLİK GRAFİK + KAMERA LİSTESİ -->
<div class="row g-3 mb-4">

    <div class="col-xl-8">
        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">
                    <i class="bi bi-bar-chart-fill"></i>
                    Saatlik Yoğunluk Analizi
                </div>
                <div class="d-flex align-items-center gap-2">
                    <span class="canli-badge"><span class="canli-nokta"></span> CANLI</span>
                    <select class="form-select form-select-sm" id="grafik-kamera-sec"
                            style="width:auto;font-size:12px;"
                            onchange="saatlikGrafikYukle(this.value)">
                        @foreach (var k in Model.Kameralar)
                        {
                            <option value="@k.Id">@k.Ad</option>
                        }
                    </select>
                </div>
            </div>
            <div class="panel-body">
                <canvas id="saatlikGrafik" height="90"></canvas>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="panel h-100">
            <div class="panel-header">
                <div class="panel-title">
                    <i class="bi bi-camera-video-fill"></i>
                    Kamera Durumları
                </div>
                <small class="text-muted" id="kamera-guncelleme-zaman">--:--</small>
            </div>
            <div class="panel-body" style="padding:14px;">
                <div id="kamera-listesi">
                    @foreach (var kamera in Model.Kameralar)
                    {
                        var sonDakika = Model.SonDakikaVerileri.GetValueOrDefault(kamera.Id);
                        var kisiSayisi = sonDakika?.Veri?.ToplamKisi ?? 0;

                        <div class="kamera-card" id="kamera-card-@kamera.Id">
                            <div class="kamera-avatar">
                                <i class="bi bi-camera-video-fill"></i>
                            </div>
                            <div class="kamera-info">
                                <div class="kamera-ad">
                                    <span class="aktif-dot @(kamera.Aktif ? "aktif" : "pasif")"></span>
                                    @kamera.Ad
                                </div>
                                <div class="kamera-konum">
                                    <i class="bi bi-geo-alt"></i> @kamera.Konum
                                </div>
                            </div>
                            <div class="kamera-badge">
                                <div class="kisi-sayi" id="kamera-kisi-@kamera.Id">@kisiSayisi</div>
                                <div class="kisi-label">kişi</div>
                            </div>
                        </div>
                    }
                    @if (!Model.Kameralar.Any())
                    {
                        <div class="text-center py-4 text-muted">
                            <i class="bi bi-camera-video-off fs-1 d-block mb-2"></i>
                            <small>Kamera bulunamadı.<br>API üzerinden kamera ekleyin.</small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- HAFTALIK ÖZET + 7 GÜNLÜK TREND -->
<div class="row g-3 mb-4">

    <div class="col-xl-5">
        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">
                    <i class="bi bi-calendar3-week-fill"></i>
                    Haftalık Özet
                </div>
                <small class="text-muted">Son 7 gün</small>
            </div>
            <div class="panel-body" style="padding:0;">
                @{
                    var gunlukDetay = Model.HaftalikRapor?.GunlukDetay ?? new();
                    var maxToplam = gunlukDetay.Any() ? gunlukDetay.Max(g => g.GunlukToplam) : 1;
                }
                @if (gunlukDetay.Any())
                {
                    <table class="rapor-tablo">
                        <thead>
                            <tr>
                                <th>Tarih</th>
                                <th>Toplam Kişi</th>
                                <th>Ortalama</th>
                                <th>Yoğunluk</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var gun in gunlukDetay.OrderByDescending(g => g.Gun))
                            {
                                var oran = maxToplam > 0 ? (gun.GunlukToplam * 100 / maxToplam) : 0;
                                <tr>
                                    <td>@gun.Gun.ToString("dd MMM")</td>
                                    <td class="deger">@gun.GunlukToplam.ToString("N0")</td>
                                    <td>@gun.GunlukOrtalama.ToString("F1")</td>
                                    <td style="min-width:80px;">
                                        <div class="yogunluk-bar">
                                            <div class="yogunluk-bar-ic" style="width:@oran%"></div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center py-4 text-muted p-3">
                        <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                        <small>Haftalık veri henüz mevcut değil.</small>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-7">
        <div class="panel">
            <div class="panel-header">
                <div class="panel-title">
                    <i class="bi bi-graph-up"></i>
                    7 Günlük Trend
                </div>
                <select class="form-select form-select-sm" id="trend-kamera-sec"
                        style="width:auto;font-size:12px;"
                        onchange="haftalikGrafikYukle(this.value)">
                    @foreach (var k in Model.Kameralar)
                    {
                        <option value="@k.Id">@k.Ad</option>
                    }
                </select>
            </div>
            <div class="panel-body">
                <canvas id="haftalikGrafik" height="120"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- ++ HAVA DURUMU ÖNİZLEME PANELİ -->
<div class="row g-3">
    <div class="col-12">
        <div class="panel" style="background:var(--mavi-koyu); border-color:rgba(255,255,255,.1);">
            <div class="panel-header" style="border-bottom-color:rgba(255,255,255,.1);">
                <div class="panel-title" style="color:#fff;">
                    <i class="bi bi-cloud-sun-fill" style="color:#f59e0b;"></i>
                    Hava Durumu
                </div>
                <a href="/Dashboard/HavaDurumu"
                   style="display:inline-flex; align-items:center; gap:6px;
                          padding:7px 16px; background:rgba(255,255,255,.08);
                          border:1px solid rgba(255,255,255,.2); border-radius:8px;
                          color:#93c5fd; text-decoration:none; font-size:13px; font-weight:600;
                          transition:all .2s;"
                   onmouseover="this.style.background='rgba(255,255,255,.15)'"
                   onmouseout="this.style.background='rgba(255,255,255,.08)'">
                    <i class="bi bi-arrow-right-circle"></i> Detaylı Görünüm
                </a>
            </div>
            <div class="panel-body">
                <div id="hava-onizleme-listesi"
                     style="display:flex; gap:12px; flex-wrap:wrap; align-items:center;">
                    <span style="color:rgba(255,255,255,.4); font-size:13px;">Yükleniyor...</span>
                </div>
            </div>
        </div>
    </div>
</div>

<button class="btn btn-sm btn-outline-primary"
        data-bs-toggle="modal" data-bs-target="#plakaModal">
    <i class="bi bi-car-front-fill me-1"></i>Plaka Tanı
</button>

<!-- ++ YENİ: Araç Sayım butonu -->
<button class="btn btn-sm btn-outline-success"
        data-bs-toggle="modal" data-bs-target="#aracSayModal">
    <i class="bi bi-truck me-1"></i>Araç Say
</button>

<button class="btn btn-sm btn-outline-warning"
        data-bs-toggle="modal" data-bs-target="#trafikModal">
    <i class="bi bi-traffic-cone me-1"></i>Trafik Yoğunluk
</button>

<!-- PLAKA MODAL -->
<div class="modal fade" id="plakaModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" style="background:var(--panel-bg); color:var(--text-primary);">
            <div class="modal-header" style="border-color:var(--border-color);">
                <h5 class="modal-title">
                    <i class="bi bi-car-front-fill me-2"></i>Plaka Tanıma
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">

                <!-- Yükleme alanı -->
                <div id="plaka-drop-alan"
                     style="border:2px dashed var(--border-color); border-radius:12px;
                            padding:40px; text-align:center; cursor:pointer;
                            transition:border-color .2s;"
                     onclick="document.getElementById('plaka-dosya').click()"
                     ondragover="event.preventDefault();this.style.borderColor='#2563EB'"
                     ondragleave="this.style.borderColor='var(--border-color)'"
                     ondrop="plakaDrop(event)">
                    <i class="bi bi-cloud-arrow-up-fill fs-1"
                       style="color:#2563EB; display:block; margin-bottom:10px;"></i>
                    <div style="font-size:14px; color:var(--text-secondary);">
                        Görüntüyü buraya sürükleyin ya da tıklayın
                    </div>
                    <small style="color:var(--text-secondary);">JPG · PNG · BMP</small>
                    <input type="file" id="plaka-dosya" accept=".jpg,.jpeg,.png,.bmp"
                           style="display:none" onchange="plakaYukle(this.files[0])">
                </div>

                <!-- Önizleme -->
                <div id="plaka-onizleme" style="display:none; margin-top:16px; text-align:center;">
                    <img id="plaka-onizleme-img" src=""
                         style="max-height:200px; border-radius:8px;
                                border:1px solid var(--border-color);">
                </div>

                <!-- Yükleniyor -->
                <div id="plaka-yukleniyor" style="display:none; text-align:center; margin-top:20px;">
                    <div class="spinner-border text-primary" role="status"></div>
                    <div style="margin-top:8px; font-size:13px; color:var(--text-secondary);">
                        Python servisi işliyor...
                    </div>
                </div>

                <!-- Sonuçlar -->
                <div id="plaka-sonuclar" style="margin-top:16px;"></div>
            </div>
            <div class="modal-footer" style="border-color:var(--border-color);">
                <button class="btn btn-sm btn-secondary"
                        data-bs-dismiss="modal">
                    Kapat
                </button>
                <button class="btn btn-sm btn-primary"
                        onclick="plakaTemizle()">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Temizle
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ARAÇ SAYIM MODAL -->
<div class="modal fade" id="aracSayModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content" style="background:var(--panel-bg); color:var(--text-primary);">

            <div class="modal-header" style="border-color:var(--border-color);">
                <h5 class="modal-title">
                    <i class="bi bi-camera-video me-2"></i>Araç Sayımı
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        onclick="aracDurdur()"></button>
            </div>

            <div class="modal-body">

                <!-- Giriş satırı -->
                <div style="display:flex; gap:8px; margin-bottom:12px; align-items:center;">
                    <input type="text" id="arac-url-input"
                           placeholder="rtsp://... veya https://www.youtube.com/watch?v=..."
                           style="flex:1; padding:9px 14px; border-radius:8px;
                        border:1px solid var(--border-color);
                        background:var(--sidebar-bg); color:var(--text-primary); font-size:13px;">
                    <input type="number" id="arac-max-kare" value="0" min="0" max="9999"
                           title="0 = süresiz (RTSP için önerilir)"
                           style="width:80px; padding:9px 10px; border-radius:8px;
                        border:1px solid var(--border-color);
                        background:var(--sidebar-bg); color:var(--text-primary);
                        font-size:13px; text-align:center;">
                    <small style="color:var(--text-secondary); white-space:nowrap;">
                        maks. kare<br><span style="font-size:10px;">(0=sonsuz)</span>
                    </small>
                    <button onclick="aracSayBaslat()" id="arac-say-btn"
                            style="padding:9px 20px; border-radius:8px; background:#16a34a;
                         color:#fff; border:none; font-size:13px; font-weight:600;
                         cursor:pointer; white-space:nowrap;"
                            onmouseover="this.style.background='#15803d'"
                            onmouseout="this.style.background='#16a34a'">
                        <i class="bi bi-play-fill me-1"></i>Başlat
                    </button>
                    <button onclick="aracDurdur()" id="arac-dur-btn" disabled
                            style="padding:9px 16px; border-radius:8px; background:#dc2626;
                         color:#fff; border:none; font-size:13px; font-weight:600;
                         cursor:pointer; white-space:nowrap; opacity:.5;"
                            onmouseover="if(!this.disabled)this.style.background='#b91c1c'"
                            onmouseout="this.style.background='#dc2626'">
                        <i class="bi bi-stop-fill me-1"></i>Durdur
                    </button>
                </div>

                <!-- Ana içerik: sol video, sağ istatistik -->
                <div style="display:flex; gap:14px;">

                    <!-- Video alanı -->
                    <div style="flex:1; min-width:0;">
                        <div id="arac-video-kapsayici"
                             style="background:#000; border-radius:10px; overflow:hidden;
                        border:1px solid var(--border-color);
                        aspect-ratio:16/9; display:flex;
                        align-items:center; justify-content:center;">
                            <div id="arac-video-placeholder"
                                 style="color:var(--text-secondary); font-size:13px; text-align:center;">
                                <i class="bi bi-camera-video" style="font-size:40px; display:block; margin-bottom:8px;"></i>
                                Video akışı burada görünecek
                            </div>
                            <img id="arac-video-img" src="" alt="Canlı Akış"
                                 style="display:none; width:100%; height:100%; object-fit:contain;">
                        </div>
                        <!-- Durum çubuğu -->
                        <div id="arac-durum-bar"
                             style="margin-top:6px; font-size:11px; color:var(--text-secondary);
                        display:flex; justify-content:space-between;">
                            <span id="arac-durum-metin">—</span>
                            <span id="arac-kare-sayaci">Kare: 0</span>
                        </div>
                    </div>

                    <!-- İstatistik paneli -->
                    <div style="width:220px; flex-shrink:0; display:flex; flex-direction:column; gap:10px;">

                        <!-- Anlık sayım kartı -->
                        <div style="background:rgba(22,163,74,.1); border:1px solid rgba(22,163,74,.25);
                        border-radius:10px; padding:14px;">
                            <div style="font-size:11px; color:var(--text-secondary); margin-bottom:4px;">
                                ANLITIK KARE
                            </div>
                            <div id="stat-anlik" style="font-size:32px; font-weight:800; color:#16a34a; line-height:1;">0</div>
                            <div style="font-size:11px; color:var(--text-secondary); margin-top:2px;">araç bu karede</div>
                        </div>

                        <!-- En yüksek kartı -->
                        <div style="background:rgba(59,130,246,.1); border:1px solid rgba(59,130,246,.25);
                        border-radius:10px; padding:14px;">
                            <div style="font-size:11px; color:var(--text-secondary); margin-bottom:4px;">
                                EN YÜKSEK (tüm video)
                            </div>
                            <div id="stat-en-yuksek" style="font-size:32px; font-weight:800; color:#3b82f6; line-height:1;">0</div>
                            <div style="font-size:11px; color:var(--text-secondary); margin-top:2px;">eş zamanlı araç</div>
                        </div>

                        <!-- Sınıf listesi -->
                        <div style="background:var(--sidebar-bg); border:1px solid var(--border-color);
                        border-radius:10px; padding:14px; flex:1; overflow-y:auto; max-height:260px;">
                            <div style="font-size:11px; color:var(--text-secondary); margin-bottom:8px;">
                                ARAÇ SINIFLARI
                            </div>
                            <div id="stat-siniflar">
                                <div style="font-size:12px; color:var(--text-secondary);">—</div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Yükleniyor -->
                <div id="arac-yukleniyor"
                     style="display:none; text-align:center; padding:20px 0; font-size:13px;
                    color:var(--text-secondary);">
                    <div class="spinner-border spinner-border-sm text-success me-2" role="status"></div>
                    Bağlanıyor, lütfen bekleyin...
                </div>

            </div>

            <div class="modal-footer" style="border-color:var(--border-color);">
                <button class="btn btn-sm btn-secondary" data-bs-dismiss="modal"
                        onclick="aracDurdur()">
                    Kapat
                </button>
                <button class="btn btn-sm btn-outline-secondary" onclick="aracSayTemizle()">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Temizle
                </button>
            </div>

        </div>
    </div>
</div>


<!-- TRAFİK YOĞUNLUK MODAL -->
<div class="modal fade" id="trafikModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content" style="background:var(--panel-bg); color:var(--text-primary);">

            <div class="modal-header" style="border-color:var(--border-color);">
                <h5 class="modal-title">
                    <i class="bi bi-traffic-cone me-2"></i>Trafik Yoğunluk Analizi
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        data-bs-dismiss="modal" onclick="trafikDurdur()"></button>
            </div>

            <div class="modal-body">

                <!-- Giriş satırı -->
                <div style="display:flex; gap:8px; margin-bottom:12px; align-items:center;">
                    <input type="text" id="trafik-url-input"
                           placeholder="rtsp://... veya https://...m3u8 veya YouTube linki"
                           style="flex:1; padding:9px 14px; border-radius:8px;
                        border:1px solid var(--border-color);
                        background:var(--sidebar-bg); color:var(--text-primary);
                        font-size:13px;">
                    <button onclick="trafikBaslat()" id="trafik-baslat-btn"
                            style="padding:9px 20px; border-radius:8px; background:#2563eb;
                         color:#fff; border:none; font-size:13px; font-weight:600;
                         cursor:pointer; white-space:nowrap;"
                            onmouseover="this.style.background='#1d4ed8'"
                            onmouseout="this.style.background='#2563eb'">
                        <i class="bi bi-play-fill me-1"></i>Başlat
                    </button>
                    <button onclick="trafikDurdur()" id="trafik-dur-btn" disabled
                            style="padding:9px 16px; border-radius:8px; background:#dc2626;
                         color:#fff; border:none; font-size:13px; font-weight:600;
                         cursor:pointer; white-space:nowrap; opacity:.5;"
                            onmouseover="if(!this.disabled)this.style.background='#b91c1c'"
                            onmouseout="this.style.background='#dc2626'">
                        <i class="bi bi-stop-fill me-1"></i>Durdur
                    </button>
                </div>

                <!-- Ana içerik -->
                <div style="display:flex; gap:14px;">

                    <!-- Video -->
                    <div style="flex:1; min-width:0;">
                        <div style="background:#000; border-radius:10px; overflow:hidden;
                        border:1px solid var(--border-color); aspect-ratio:16/9;
                        display:flex; align-items:center; justify-content:center;">
                            <div id="trafik-placeholder"
                                 style="color:var(--text-secondary); font-size:13px; text-align:center;">
                                <i class="bi bi-traffic-cone"
                                   style="font-size:40px; display:block; margin-bottom:8px;"></i>
                                Video akışı burada görünecek
                            </div>
                            <img id="trafik-video-img" src="" alt="Trafik Akışı"
                                 style="display:none; width:100%; height:100%; object-fit:contain;">
                        </div>
                        <div style="margin-top:6px; font-size:11px; color:var(--text-secondary);
                        display:flex; justify-content:space-between;">
                            <span id="trafik-durum-metin">—</span>
                            <span id="trafik-kare-sayaci">Kare: 0</span>
                        </div>
                    </div>

                    <!-- İstatistik paneli -->
                    <div style="width:220px; flex-shrink:0; display:flex; flex-direction:column; gap:10px;">

                        <!-- Yoğunluk kartı -->
                        <div id="trafik-yogunluk-kart"
                             style="border-radius:10px; padding:16px;
                        background:rgba(37,99,235,.1); border:1px solid rgba(37,99,235,.25);
                        text-align:center;">
                            <div style="font-size:11px; color:var(--text-secondary); margin-bottom:6px;">
                                GÜNCEL DURUM
                            </div>
                            <div id="trafik-etiket"
                                 style="font-size:28px; font-weight:800; color:#2563eb; letter-spacing:2px;">
                                —
                            </div>
                            <div id="trafik-oran"
                                 style="font-size:13px; color:var(--text-secondary); margin-top:4px;">
                                Değişim: —
                            </div>
                        </div>

                        <!-- Ortalama / Maks -->
                        <div style="background:var(--sidebar-bg); border:1px solid var(--border-color);
                        border-radius:10px; padding:14px; display:flex; flex-direction:column;
                        gap:10px;">
                            <div>
                                <div style="font-size:10px; color:var(--text-secondary);">ORTALAMA DEĞİŞİM</div>
                                <div id="trafik-ortalama"
                                     style="font-size:22px; font-weight:700; color:#2563eb;">
                                    —
                                </div>
                            </div>
                            <div style="border-top:1px solid var(--border-color); padding-top:10px;">
                                <div style="font-size:10px; color:var(--text-secondary);">MAKSİMUM DEĞİŞİM</div>
                                <div id="trafik-maksimum"
                                     style="font-size:22px; font-weight:700; color:#7c3aed;">
                                    —
                                </div>
                            </div>
                        </div>

                        <!-- Mini grafik -->
                        <div style="background:var(--sidebar-bg); border:1px solid var(--border-color);
                        border-radius:10px; padding:14px; flex:1;">
                            <div style="font-size:10px; color:var(--text-secondary); margin-bottom:8px;">
                                YOĞUNLUK GEÇMİŞİ
                            </div>
                            <canvas id="trafik-grafik" height="80"
                                    style="width:100%; display:block;"></canvas>
                        </div>

                    </div>
                </div>

                <!-- Yükleniyor -->
                <div id="trafik-yukleniyor"
                     style="display:none; text-align:center; padding:16px 0;
                    font-size:13px; color:var(--text-secondary);">
                    <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                    Bağlanıyor...
                </div>

            </div>

            <div class="modal-footer" style="border-color:var(--border-color);">
                <button class="btn btn-sm btn-secondary" data-bs-dismiss="modal"
                        onclick="trafikDurdur()">
                    Kapat
                </button>
                <button class="btn btn-sm btn-outline-secondary" onclick="trafikTemizle()">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Temizle
                </button>
            </div>

        </div>
    </div>
</div>


<style>
