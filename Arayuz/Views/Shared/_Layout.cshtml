<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Belediye Kamera Takip Sistemi</title>

    <!-- Google Fonts: Kurumsal + Okunabilir -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>

    <style>
        :root {
            --mavi-koyu:    #0D2B55;
            --mavi-orta:    #1A4A8A;
            --mavi-parlak:  #2563EB;
            --mavi-acik:    #DBEAFE;
            --altin:        #C8901A;
            --altin-acik:   #FEF3C7;
            --yesil:        #16A34A;
            --kirmizi:      #DC2626;
            --turuncu:      #EA580C;
            --beyaz:        #FFFFFF;
            --gri-100:      #F1F5F9;
            --gri-200:      #E2E8F0;
            --gri-400:      #94A3B8;
            --gri-600:      #475569;
            --gri-900:      #0F172A;
            --sidebar-w:    260px;
            --header-h:     64px;
            --radius:       10px;
            --shadow-sm:    0 1px 3px rgba(13,43,85,.10);
            --shadow-md:    0 4px 16px rgba(13,43,85,.12);
            --shadow-lg:    0 8px 32px rgba(13,43,85,.16);
            --transition:   all .22s cubic-bezier(.4,0,.2,1);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--gri-100);
            color: var(--gri-900);
            overflow-x: hidden;
        }

        /* ── SİDEBAR ── */
        .sidebar {
            position: fixed;
            top: 0; left: 0;
            width: var(--sidebar-w);
            height: 100vh;
            background: var(--mavi-koyu);
            display: flex;
            flex-direction: column;
            z-index: 100;
            box-shadow: 4px 0 20px rgba(0,0,0,.18);
            transition: var(--transition);
        }

        .sidebar-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 22px 20px 18px;
            border-bottom: 1px solid rgba(255,255,255,.1);
        }

        .sidebar-logo .logo-icon {
            width: 40px; height: 40px;
            background: var(--altin);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: 20px;
            color: var(--mavi-koyu);
            font-weight: 700;
            flex-shrink: 0;
        }

        .sidebar-logo .logo-text {
            line-height: 1.2;
        }
        .sidebar-logo .logo-text strong {
            display: block;
            color: #fff;
            font-family: 'Source Serif 4', serif;
            font-size: 14px;
            font-weight: 700;
            letter-spacing: .3px;
        }
        .sidebar-logo .logo-text span {
            font-size: 11px;
            color: var(--gri-400);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .sidebar-nav {
            flex: 1;
            padding: 16px 12px;
            overflow-y: auto;
        }

        .nav-section-title {
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--gri-400);
            padding: 12px 8px 6px;
            font-weight: 600;
        }

        .nav-item a {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 12px;
            border-radius: 7px;
            color: rgba(255,255,255,.72);
            text-decoration: none;
            font-size: 13.5px;
            font-weight: 400;
            transition: var(--transition);
        }
        .nav-item a:hover,
        .nav-item a.active {
            background: rgba(255,255,255,.1);
            color: #fff;
        }
        .nav-item a.active {
            background: var(--mavi-parlak);
            color: #fff;
            font-weight: 500;
        }
        .nav-item a i { font-size: 16px; opacity: .85; }

        .sidebar-footer {
            padding: 14px 20px;
            border-top: 1px solid rgba(255,255,255,.08);
        }
        .sidebar-footer .sistem-durum {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            color: rgba(255,255,255,.55);
        }
        .durum-nokta {
            width: 7px; height: 7px;
            border-radius: 50%;
            background: var(--yesil);
            animation: pulse-green 2s infinite;
        }
        @@keyframes pulse-green {
            0%,100% { opacity: 1; box-shadow: 0 0 0 0 rgba(22,163,74,.4); }
            50% { opacity: .7; box-shadow: 0 0 0 4px rgba(22,163,74,0); }
        }

        /* ── HEADER ── */
        .topbar {
            position: fixed;
            top: 0;
            left: var(--sidebar-w);
            right: 0;
            height: var(--header-h);
            background: var(--beyaz);
            border-bottom: 1px solid var(--gri-200);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 28px;
            z-index: 99;
            box-shadow: var(--shadow-sm);
        }

        .topbar-left h1 {
            font-family: 'Source Serif 4', serif;
            font-size: 18px;
            font-weight: 700;
            color: var(--mavi-koyu);
        }
        .topbar-left .breadcrumb-text {
            font-size: 12px;
            color: var(--gri-400);
            margin-top: 1px;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .son-guncelleme-badge {
            display: flex;
            align-items: center;
            gap: 6px;
            background: var(--mavi-acik);
            color: var(--mavi-orta);
            border-radius: 20px;
            padding: 5px 12px;
            font-size: 12px;
            font-weight: 500;
        }

        .refresh-btn {
            width: 34px; height: 34px;
            border-radius: 8px;
            border: 1px solid var(--gri-200);
            background: white;
            display: flex; align-items: center; justify-content: center;
            cursor: pointer;
            transition: var(--transition);
            color: var(--gri-600);
        }
        .refresh-btn:hover { background: var(--gri-100); color: var(--mavi-parlak); }

        /* ── ANA İÇERİK ── */
        .main-content {
            margin-left: var(--sidebar-w);
            margin-top: var(--header-h);
            padding: 28px;
            min-height: calc(100vh - var(--header-h));
        }

        /* ── KPI KARTLARI ── */
        .kpi-card {
            background: var(--beyaz);
            border-radius: var(--radius);
            padding: 20px 22px;
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--gri-200);
            position: relative;
            overflow: hidden;
            transition: var(--transition);
        }
        .kpi-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }

        .kpi-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0;
            width: 4px; height: 100%;
            border-radius: 4px 0 0 4px;
        }
        .kpi-card.mavi::before  { background: var(--mavi-parlak); }
        .kpi-card.yesil::before { background: var(--yesil); }
        .kpi-card.altin::before { background: var(--altin); }
        .kpi-card.turuncu::before { background: var(--turuncu); }

        .kpi-label {
            font-size: 11.5px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--gri-400);
            font-weight: 600;
            margin-bottom: 8px;
        }
        .kpi-value {
            font-size: 34px;
            font-weight: 700;
            font-family: 'Source Serif 4', serif;
            color: var(--mavi-koyu);
            line-height: 1;
            margin-bottom: 8px;
        }
        .kpi-meta {
            font-size: 12px;
            color: var(--gri-400);
        }
        .kpi-icon {
            position: absolute;
            right: 18px; top: 18px;
            width: 40px; height: 40px;
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            font-size: 18px;
        }
        .kpi-card.mavi   .kpi-icon { background: var(--mavi-acik);   color: var(--mavi-parlak); }
        .kpi-card.yesil  .kpi-icon { background: #DCFCE7; color: var(--yesil); }
        .kpi-card.altin  .kpi-icon { background: var(--altin-acik);  color: var(--altin); }
        .kpi-card.turuncu .kpi-icon { background: #FFF7ED; color: var(--turuncu); }

        /* ── PANEL KARTI ── */
        .panel {
            background: var(--beyaz);
            border-radius: var(--radius);
            border: 1px solid var(--gri-200);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
            margin-bottom: 24px;
        }

        .panel-header {
            padding: 16px 22px;
            border-bottom: 1px solid var(--gri-200);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .panel-title {
            font-family: 'Source Serif 4', serif;
            font-size: 15px;
            font-weight: 700;
            color: var(--mavi-koyu);
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .panel-title i { color: var(--mavi-parlak); }
        .panel-body { padding: 22px; }

        /* ── KAMERA KARTI ── */
        .kamera-card {
            background: var(--gri-100);
            border: 1px solid var(--gri-200);
            border-radius: 8px;
            padding: 14px 16px;
            display: flex;
            align-items: center;
            gap: 14px;
            transition: var(--transition);
            margin-bottom: 10px;
        }
        .kamera-card:hover { border-color: var(--mavi-parlak); background: var(--mavi-acik); }

        .kamera-avatar {
            width: 42px; height: 42px;
            border-radius: 8px;
            background: var(--mavi-orta);
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 18px;
            flex-shrink: 0;
        }
        .kamera-info { flex: 1; min-width: 0; }
        .kamera-ad {
            font-size: 13.5px;
            font-weight: 600;
            color: var(--mavi-koyu);
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .kamera-konum {
            font-size: 11.5px;
            color: var(--gri-400);
            margin-top: 2px;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .kamera-badge {
            text-align: right;
        }
        .kisi-sayi {
            font-size: 22px;
            font-weight: 700;
            font-family: 'Source Serif 4', serif;
            color: var(--mavi-koyu);
        }
        .kisi-label { font-size: 10px; color: var(--gri-400); text-transform: uppercase; letter-spacing: .8px; }

        .aktif-dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 4px;
        }
        .aktif-dot.aktif   { background: var(--yesil); animation: pulse-green 2s infinite; }
        .aktif-dot.pasif   { background: var(--gri-400); }

        /* ── HAFTALIK TABLO ── */
        .rapor-tablo { width: 100%; border-collapse: collapse; }
        .rapor-tablo th {
            background: var(--mavi-koyu);
            color: rgba(255,255,255,.85);
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 10px 14px;
            font-weight: 600;
            text-align: left;
        }
        .rapor-tablo td {
            padding: 11px 14px;
            font-size: 13px;
            border-bottom: 1px solid var(--gri-200);
            color: var(--gri-600);
        }
        .rapor-tablo tr:last-child td { border-bottom: none; }
        .rapor-tablo tr:hover td { background: var(--mavi-acik); }
        .rapor-tablo .deger { font-weight: 600; color: var(--mavi-koyu); }

        .yogunluk-bar {
            height: 6px;
            border-radius: 3px;
            background: var(--gri-200);
            margin-top: 4px;
        }
        .yogunluk-bar-ic {
            height: 100%;
            border-radius: 3px;
            background: linear-gradient(90deg, var(--mavi-parlak), var(--altin));
            transition: width .6s ease;
        }

        /* ── CANLI İNDİKATÖR ── */
        .canli-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            background: #FEF2F2;
            color: var(--kirmizi);
            border: 1px solid #FECACA;
            border-radius: 20px;
            padding: 3px 10px;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: .5px;
        }
        .canli-nokta {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: var(--kirmizi);
            animation: pulse-red 1.2s infinite;
        }
        @@keyframes pulse-red {
            0%,100% { opacity: 1; }
            50% { opacity: .3; }
        }

        /* ── HATA MESAJI ── */
        .api-uyari {
            background: #FFF7ED;
            border: 1px solid #FED7AA;
            border-left: 4px solid var(--turuncu);
            border-radius: 8px;
            padding: 14px 18px;
            margin-bottom: 20px;
            display: flex; align-items: center; gap: 10px;
            font-size: 13px; color: var(--turuncu);
        }

        /* ── GRAFİK SEÇICI ── */
        .grafik-selector .btn-check + .btn {
            border-radius: 6px;
            font-size: 12px;
            padding: 5px 12px;
            font-weight: 500;
        }

        /* ── RESPONSIVE ── */
        @@media (max-width: 768px) {
            .sidebar { transform: translateX(-100%); }
            .main-content, .topbar { margin-left: 0; left: 0; }
        }
    </style>
</head>
<body>

    <!-- ── SIDEBAR ── -->
    <aside class="sidebar">
        <div class="sidebar-logo">
            <div class="logo-icon">B</div>
            <div class="logo-text">
                <strong>Belediye Kamera</strong>
                <span>Takip Sistemi</span>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-title">Ana Menü</div>
            <ul class="nav-item list-unstyled">
                <li>
                    <a href="/Dashboard/Index" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                        <i class="bi bi-grid-1x2-fill"></i> Dashboard
                    </a>
                </li>
            </ul>

            <div class="nav-section-title" style="margin-top:12px;">Raporlar</div>
            <ul class="nav-item list-unstyled">
                <li><a href="#"><i class="bi bi-bar-chart-line-fill"></i> Saatlik Analiz</a></li>
                <li><a href="#"><i class="bi bi-calendar3-week-fill"></i> Haftalık Rapor</a></li>
                <li><a href="#"><i class="bi bi-download"></i> Veri Dışa Aktar</a></li>
            </ul>

            <div class="nav-section-title" style="margin-top:12px;">Sistem</div>
            <ul class="nav-item list-unstyled">
                <li><a href="#"><i class="bi bi-camera-video-fill"></i> Kamera Yönetimi</a></li>
                <li><a href="#"><i class="bi bi-gear-fill"></i> Ayarlar</a></li>
            </ul>
        </nav>

        <div class="sidebar-footer">
            <div class="sistem-durum">
                <span class="durum-nokta"></span>
                <span>Sistem Aktif · v1.0</span>
            </div>
        </div>
    </aside>

    <!-- ── TOPBAR ── -->
    <header class="topbar">
        <div class="topbar-left">
            <h1>@(ViewData["Title"] ?? "Dashboard")</h1>
            <div class="breadcrumb-text">Belediye Kamera Takip Sistemi / @(ViewData["Title"] ?? "Genel Bakış")</div>
        </div>
        <div class="topbar-right">
            <div class="son-guncelleme-badge">
                <i class="bi bi-clock"></i>
                <span id="clock">--:--:--</span>
            </div>
            <button class="refresh-btn" onclick="sayfaYenile()" title="Yenile">
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
    </header>

    <!-- ── ANA İÇERİK ── -->
    <main class="main-content">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Saat
        function saatiGuncelle() {
            document.getElementById('clock').textContent =
                new Date().toLocaleTimeString('tr-TR');
        }
        setInterval(saatiGuncelle, 1000);
        saatiGuncelle();

        function sayfaYenile() {
            const btn = document.querySelector('.refresh-btn i');
            btn.style.transform = 'rotate(360deg)';
            btn.style.transition = 'transform .5s ease';
            setTimeout(() => { btn.style.transform = ''; btn.style.transition = ''; }, 500);
            location.reload();
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
